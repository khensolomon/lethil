{
  "name": "lethil",
  "version": "1.3.1",
  "description": "...a minimal and configurable Node.js web framework!",
  "main": "./dist/lethil.js",
  "module": "./lethil.mjs",
  "types": "./types/lethil.d.ts",
  "-type": "module",
  "scripts": {
    "prepublishOnly": "npm run task:prepublish",
    "build": "npm run build:cjs",
    "build:cjs": "tsc -p tsconfig-cjs.json",
    "build:esm": "tsc -p tsconfig-esm.json",
    "lint": "eslint . --ext .js",
    "watch": "tsc --watch --project ./tsconfig.json",
    "task:prepublish": "node ./task.prepublish.mjs",
    "tst": "mocha",
    "test": "mocha test/mocha-*.mjs",
    "test:current": "mocha test/mocha-utility.mjs",
    "test:ts": "mocha -r ts-node/register test/*.ts",
    "test:ts-current": "mocha -r ts-node/register"
  },
  "files": [
    "lib",
    "test",
    "dist",
    "types",
    "lethil.mjs"
  ],
  "babel": {
    "presets": [
      [
        "@babel/preset-env",
        {
          "targets": {
            "node": "current"
          }
        }
      ]
    ],
    "plugins": []
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^4.9.4",
    "@types/node": "^18.11.18",
    "mocha": "^10.2.0",
    "@babel/core": "^7.20.12",
    "@babel/preset-env": "^7.20.2"
  },
  "docs": {
    "live": {
      "main": "./dist/lethil.js",
      "module": "./lethil.mjs",
      "types": "./types/lethil.d.ts"
    },
    "test": {
      "main": "./lib/lethil.js",
      "module": "./lib/lethil.js"
    },
    "local": {
      "main": "./lib/lethil.js",
      "module": "./lib/lethil.js",
      "types": "./types/lethil.js",
      "type": "module"
    },
    "type": {
      "help": [
        "[type] need to disabled when publishing, nor never need if nothing to import from module",
        "but required in development",
        "NOTE: publish to npm before git commit"
      ]
    }
  },
  "exports---": {
    ".": {
      "import": {
        "node": "./lethil.mjs",
        "default": "./dist/lethil.js"
      },
      "require": "./dist/lethil.js",
      "types": "./types/lethil.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/khensolomon/lethil.git"
  },
  "keywords": [
    "web",
    "framework",
    "command line interface",
    "minimal",
    "configurable",
    "pug",
    "mysql",
    "classic",
    "reverse proxy",
    "server"
  ],
  "author": "Khen Solomon Lethil",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/khensolomon/lethil/issues"
  },
  "homepage": "https://github.com/khensolomon/lethil/#readme",
  "engines": {
    "node": ">=16.x"
  }
}