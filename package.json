{
  "name": "lethil",
  "version": "1.3.4",
  "description": "...a minimal and configurable Node.js web framework!",
  "main": "./dist/lethil.js",
  "module": "./lethil.mjs",
  "types": "./types/lethil.d.ts",
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "npm run build:cjs",
    "build:cjs": "tsc -p tsconfig-cjs.json",
    "build:esm": "tsc -p tsconfig-esm.json",
    "lint": "eslint . --ext .js",
    "watch": "tsc --watch --project ./tsconfig.json",
    "tst": "mocha",
    "test": "mocha test/mocha-*.mjs --exit",
    "test:current": "mocha test/mocha-parse-cli.mjs",
    "test:ts": "mocha -r ts-node/register test/*.ts",
    "test:ts-current": "mocha -r ts-node/register"
  },
  "files": [
    "lib",
    "test",
    "dist",
    "types",
    "lethil.mjs"
  ],
  "babel": {
    "presets": [
      [
        "@babel/preset-env",
        {
          "targets": {
            "node": "current"
          }
        }
      ]
    ],
    "plugins": []
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@babel/core": "^7.21.4",
    "@babel/preset-env": "^7.21.4",
    "@types/express": "^4.17.17",
    "@types/node": "^18.15.11",
    "mocha": "^10.2.0",
    "typescript": "^5.0.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/khensolomon/lethil.git"
  },
  "keywords": [
    "web",
    "framework",
    "command line interface",
    "minimal",
    "configurable",
    "pug",
    "mysql",
    "classic",
    "reverse proxy",
    "server"
  ],
  "author": "Khen Solomon Lethil",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/khensolomon/lethil/issues"
  },
  "homepage": "https://github.com/khensolomon/lethil/#readme",
  "engines": {
    "node": ">=16.x"
  }
}