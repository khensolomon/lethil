{
  "name": "lethil",
  "version": "1.2.9",
  "description": "...a minimal and configurable Node.js web framework!",

  "main": "./dist/index.js",
  "module": "./index.mjs",
  "types": "./dist/index.d.ts",

  "docs": {
    "live":{
      "main": "./dist/index.js",
      "module": "./index.mjs",
      "types": "./dist/index.d.ts",
      "-type": "module"
    },
    "test":{
      "main": "./lib/index.js",
      "module": "./lib/index.js"
    },
    "local":{
      "main": "./lib/index.js",
      "module": "./lib/index.js",
      "types": "./lib/index.js",
      "type": "module"
    },
    "type": {
      "help": [
        "[type] need to disabled when publishing, nor never need if nothing to import from module",
        "but required in development",
        "NOTE: publish to npm before git commit"
      ]
    }
  },

  "exports": {
    ".": {
      "import": {
        "node": "./index.mjs",
        "default": "./dist/index.js"
      },
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "lib",
    "test",
    "dist",
    "type",
    "index.mjs"
  ],

  "scripts": {
    "prepublishOnly": "npm run task:prepublish",

    "build": "npm run build:cjs",
    "build:cjs": "tsc -p tsconfig-cjs.json",
    "build:esm": "tsc -p tsconfig-esm.json",

    "lint": "eslint . --ext .js",
    "-test": "mocha -r ts-node/register test/*.ts",
    "-test-single": "mocha -r ts-node/register",

    "watch": "tsc --watch --project ./tsconfig.json",

    "task:prepublish": "node ./task.prepublish.mjs",

    "tst": "mocha",
    "test": "mocha test/mocha-*.js",
    "test:route": "mocha test/mocha-route.js"
  },

  "repository": {
    "type": "git",
    "url": "git+https://github.com/khensolomon/lethil.git"
  },

  "keywords": [
    "web","framework",
    "command line interface",
    "minimal",
    "configurable",
    "pug",
    "mysql",
    "classic",
    "reverse proxy","server"
  ],
  "author": "Khen Solomon Lethil",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/khensolomon/lethil/issues"
  },
  "homepage": "https://github.com/khensolomon/lethil/#readme",
  "engines": {
    "node": ">=16.x"
  },
  "dependencies": {
  },
  "devDependencies": {
    "typescript": "^4.9.4",
    "@types/node": "^18.11.18",
    "mocha": "^10.2.0"
  }
}
