# lethil — secrets template
#
# Copy this file to .env in the same directory, fill in real values, then run
#   python3 script/secrets.py --push
# to sync to GitHub Secrets. The .env file is gitignored.
#
# ZONE MODEL
#   Content before the first "#@" marker is the BUNDLE zone — concatenated and
#   pushed as a single secret named ENV_BASE.
#   "#@ individual" — each key below is pushed as its own GitHub secret.
#   "#@ local"      — never pushed; read by script/secrets.py only.
#
# lethil has no bundle content (no ENV_BASE to ship), so it starts directly
# with the individual zone. A Django app .env would put production config
# above the first marker instead.

#@ individual

# ── Cloudflare ────────────────────────────────────────────────────────────
# API token: Zone.DNS.Edit (all zones), Account.Cloudflare Tunnel.Edit,
# Account.Access.Edit
CF_ACCOUNT_ID=
CF_API_TOKEN=

# Cloudflare Access service token (deploy pipeline SSH). Both halves shown
# once at creation in Zero Trust → Access → Service Auth.
CF_SERVICE_TOKEN_ID=
CF_SERVICE_TOKEN_SECRET=

# ── Cloudflare R2 (optional — rclone config) ──────────────────────────────
R2_ACCESS_KEY_ID=
R2_ACCESS_SECRET=

# ── Server (target) ───────────────────────────────────────────────────────
# Public IP or hostname of the target server.
SERVER_HOSTNAME=
SERVER_USERNAME=root

# Admin domain — hosts the subdomains defined in server/setup.py.
ADMIN_DOMAIN=

# Tunnel name — passed to setup.py --tunnel-name.
TUNNEL_NAME=

# App domains, semicolon-separated. Each entry is "domain:target".
# Example: a.example.com:http://localhost:3010;b.example.com:http://localhost:3020
APP_DOMAINS=

# ── SSH ───────────────────────────────────────────────────────────────────
# Path to the private key on the local machine. secrets.py reads the FILE
# CONTENTS and pushes them as the secret SSH_PRIVATE_KEY. The path itself is
# never pushed. The matching public key must be in the target's
# /root/.ssh/authorized_keys.
SSH_PRIVATE_KEY_PATH=~/.ssh/prod_server

# Optional: known_hosts entry for the server (strict host key checking).
SSH_KNOWN_HOSTS=

# Optional: fallback to "~/.deploy/backups / repo-slug"
STORAGE_ROOT=/opt/bucket/storage

#@ local
# ════════════════════════════════════════════════════════════════════════════
#  LOCAL / DEV ONLY  →  never pushed, never leaves this machine
# ════════════════════════════════════════════════════════════════════════════

# Never pushed. Read by script/secrets.py to identify the target repo.
REPO_OWNER=khensolomon
REPO_NAME=lethil
