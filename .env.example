# lethil — secrets template
#
# Copy this file to .env in the same directory, fill in real values, and
# run `python3 script/secrets.py --push` to sync to GitHub Secrets.
# .env is gitignored.
#
# Every key here becomes a GitHub Actions secret with the same name.
# Workflows reference them via ${{ secrets.KEY_NAME }}.

# ── Cloudflare ────────────────────────────────────────────────────────────
# API token with permissions:
#   Zone.DNS.Edit (all zones), Account.Cloudflare Tunnel.Edit, Account.Access.Edit
CF_API_TOKEN=

# Account ID. Found in the Cloudflare dashboard sidebar.
CF_ACCOUNT_ID=

# Cloudflare Access service token (for the deploy pipeline's SSH).
# Created in Zero Trust → Access → Service Auth → Service Tokens.
# Both halves are shown ONCE at creation — capture both then.
CF_SERVICE_TOKEN_ID=
CF_SERVICE_TOKEN_SECRET=

# ── Cloudflare R2 (optional — for rclone config) ──────────────────────────
# API token from R2 → Manage R2 API Tokens. Permissions: Object Read & Write.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# ── Server (target) ───────────────────────────────────────────────────────
# Public IP or hostname of the target server. Used by workflows when the
# operator dispatches without typing it into the form.
SERVER_HOST=

# Admin domain — hosts ssh.<domain>, npm.<domain>, etc. (see server/setup.py)
ADMIN_DOMAIN=

# Tunnel name — passed to setup.py --tunnel-name.
TUNNEL_NAME=

# App domains, semicolon-separated. Each entry is `domain:target`.
# Example: zaideih.example.com:http://localhost:3010;myordbok.example.com:http://localhost:3020
APP_DOMAINS=

# ── SSH ───────────────────────────────────────────────────────────────────
# Private key for SSHing into the server. The matching public key must be
# in /root/.ssh/authorized_keys on the target. Paste the full private key,
# including the BEGIN/END lines.
#
# In .env, multi-line values can be enclosed in double quotes and
# secrets.py will preserve newlines when pushing.
SSH_PRIVATE_KEY=

# Optional but recommended: known_hosts entry for the server. Strict host
# key checking will reject unknown hosts otherwise.
SSH_KNOWN_HOSTS=

# ── GitHub (for script/secrets.py) ────────────────────────────────────────
# Repository slug, used by secrets.py to know where to push.
# Format: owner/repo
REPO_OWNER=khensolomon
REPO_NAME=lethil
