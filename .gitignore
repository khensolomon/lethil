# Custom
*.v[0-9]*
tmp

# Secrets — never commit. Source of truth for local development; synced
# to GitHub Secrets via script/secrets.py.
.env

# Per-app build outputs. apps/<name>/dist/ is what gets deployed; it's
# generated, not source.
apps/*/dist/
apps/*/node_modules/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Editor / OS
.DS_Store
.vscode/
.idea/
*.swp
*~

# Logs
*.log