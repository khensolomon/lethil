---
---
[
  {% assign filtered_pages = site.pages | where_exp: "item", "item.url" %}
  {% for page in filtered_pages %}
    {% unless page.url contains '.json' or page.url contains '.xml' or page.url contains 'assets/' %}
    {
      "title": {{ page.title | default: page.name | jsonify }},
      "url": {{ page.url | relative_url | jsonify }},
      "content": {{ page.content | strip_html | strip_newlines | escape | jsonify }}
    }{% unless forloop.last %},{% endunless %}
    {% endunless %}
  {% endfor %}
]
