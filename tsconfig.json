{
  "compilerOptions": {
    "rootDir": "./lib",
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "Node",

    // "outDir": "dist",
    "declarationDir": "type",

    // "sourceMap": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "esModuleInterop": true,

    "alwaysStrict": true,
    "noImplicitThis": true,
    "removeComments": true,
    "noImplicitReturns": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "strictFunctionTypes": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "emitDecoratorMetadata": false,
    "experimentalDecorators": false,
    "forceConsistentCasingInFileNames": true,

    "strict": true,
    "checkJs": true,
    "allowJs": true,
    "watch": false
  },
  "compileOnSave": false,
  "include": ["./lib/**/*"],
  "exclude": [
    "node_modules",
    "test",
    "dist",
    "type",
    "**/*.spec.js"
  ]
}